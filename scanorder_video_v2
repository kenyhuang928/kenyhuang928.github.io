              <div class="col-block visible" data-delay="${i * 100}" style="flex:1;padding:16px;text-align:center;transform:none;opacity:0;transition:all 0.5s ${i*100}ms;">
                <div style="font-size:24px;margin-bottom:8px;">${ic}</div>
                <div style="font-size:13px;font-weight:600;color:var(--text-main);">${t}</div>
              </div>
            `).join('')}
          </div>
          <div style="flex:1;display:flex;gap:20px;overflow:hidden;">
            <div class="screenshot-panel visible" style="flex:1;width:auto;transform:none;opacity:0;transition:all 0.6s 0.4s;" id="screenshot-panel">
              <div class="screenshot-frame">
                <img src="${ASSETS}slide12_img13.png" alt="B端工单接单界面" onerror="this.style.display='none'">
              </div>
              <div class="screenshot-label">▲ 图示：B端工单接单界面（售后服务PAD端）</div>
            </div>
          </div>
        </div>
        <div class="watermark">南方商城 · 内部操作手册</div>
      </div>
    `
  },

  // ========== SLIDE 13: 总结 ==========
  {
    id: 'summary',
    chapter: '流程总结',
    duration: 10000,
    narrations: [
      { time: 0, text: '最后，让我们回顾扫码下单的完整操作流程。' },
      { time: 2000, text: '一：后台配置 → 二：小程序操作 → 三：加入购物车 → 四：提交订单 → 五：B端接单。' },
      { time: 5500, text: '掌握以上五个步骤，即可完整完成扫码下单的全链路操作。' },
      { time: 8000, text: '如有操作疑问，请联系技术支持团队。感谢观看！' },
    ],
    render: () => `
      <div class="slide summary-slide cs-layout" style="position:absolute;inset:0;">
        <div class="cs-header">
          <div class="cs-part-badge">SUMMARY</div>
          <div class="cs-title">操作流程总结</div>
        </div>
        <div class="cs-divider" style="background:linear-gradient(90deg,rgba(0,82,204,0.6),rgba(0,82,204,0.1),transparent);"></div>
        <div class="cs-body" style="padding-top:24px;">
          <div class="summary-flow">
            ${[
              ['🏢', '后台配置', '配置检测项、关联商品\n保存发布，小程序同步生效'],
              ['📱', '小程序操作', '扫码进入，查看车型商品\n按需切换车辆/商品/规格'],
              ['🛒', '加入购物车', '勾选商品，确认数量\n查看预估金额'],
              ['📋', '提交订单', '核对信息，三步校验\n确认到店服务后提交'],
              ['🖥️', 'B端接单', '服务顾问在PAD端\n作业工单中处理订单'],
            ].map(([ic, t, d], i) => i < 4 ? `
              <div class="summary-item" data-delay="${i * 200}">
                <div class="summary-circle">
                  ${ic}
                  <div class="summary-circle-num">${i+1}</div>
                </div>
                <div class="summary-label">${t}</div>
                <div class="summary-desc">${d}</div>
              </div>
              <div class="summary-arrow">→</div>
            ` : `
              <div class="summary-item" data-delay="${i * 200}">
                <div class="summary-circle">
                  ${ic}
                  <div class="summary-circle-num">${i+1}</div>
                </div>
                <div class="summary-label">${t}</div>
                <div class="summary-desc">${d}</div>
              </div>
            `).join('')}
          </div>
        </div>
        <div class="summary-footer" id="summary-footer">
          如有操作疑问，请联系技术支持团队
        </div>
        <div class="watermark">南方商城 · 内部操作手册</div>
      </div>
    `
  },
];

// ============================================================
// PLAYER ENGINE
// ============================================================
let currentSlide = 0;
let isPlaying = false;
let playTimer = null;
let narrationTimer = null;
let slideStartTime = 0;
let elapsedBeforePause = 0;
let totalDuration = slides.reduce((s, sl) => s + sl.duration, 0);

const stage = document.getElementById('stage');
const subtitleEl = document.getElementById('subtitle');
const progressFill = document.getElementById('progress-fill');
const timeDisplay = document.getElementById('time-display');
const slideCounter = document.getElementById('slide-counter');
const btnPlay = document.getElementById('btn-play');
const btnPrev = document.getElementById('btn-prev');
const btnNext = document.getElementById('btn-next');

function formatTime(ms) {
  const s = Math.floor(ms / 1000);
  const m = Math.floor(s / 60);
  return `${String(m).padStart(2,'0')}:${String(s % 60).padStart(2,'0')}`;
}

function renderSlide(idx) {
  stage.innerHTML = slides[idx].render();
  // Animate in
  const el = stage.querySelector('.slide');
  if (el) { el.classList.add('active', 'slide-enter'); }

  // Staggered card animations
  setTimeout(() => {
    document.querySelectorAll('[data-delay]').forEach(el => {
      const delay = parseInt(el.dataset.delay) || 0;
      setTimeout(() => {
        el.classList.add('visible');
        // Also handle screenshot panel
        const sp = document.getElementById('screenshot-panel');
        if (sp) sp.classList.add('visible');
        const notice = document.getElementById('slide-notice');
        if (notice) notice.classList.add('visible');
        const notice2 = document.getElementById('slide-notice2');
        if (notice2) notice2.classList.add('visible');
        const sf = document.getElementById('summary-footer');
        if (sf) sf.classList.add('visible');
      }, delay + 300);
    });
    // screenshot panel
    const sp = document.getElementById('screenshot-panel');
    if (sp) setTimeout(() => sp.classList.add('visible'), 400);
    const notice = document.getElementById('slide-notice');
    if (notice) setTimeout(() => notice.classList.add('visible'), 1200);
    const notice2 = document.getElementById('slide-notice2');
    if (notice2) setTimeout(() => notice2.classList.add('visible'), 1600);
    const sf = document.getElementById('summary-footer');
    if (sf) setTimeout(() => sf.classList.add('visible'), 2000);
  }, 100);

  slideCounter.textContent = `${idx + 1} / ${slides.length}`;
  updateChapterPills(idx);
}

function showSubtitle(text) {
  subtitleEl.classList.remove('visible');
  setTimeout(() => {
    subtitleEl.textContent = text;
    subtitleEl.classList.add('visible');
  }, 200);
}

function clearSubtitle() {
  subtitleEl.classList.remove('visible');
  setTimeout(() => { subtitleEl.textContent = ''; }, 400);
}

function scheduleNarrations(slide, startOffset = 0) {
  clearNarrationTimers();
  slide.narrations.forEach(n => {
    if (n.time >= startOffset) {
      const t = setTimeout(() => {
        showSubtitle(n.text);
      }, n.time - startOffset);
      narrationTimers.push(t);
    }
  });
}

let narrationTimers = [];
function clearNarrationTimers() {
  narrationTimers.forEach(clearTimeout);
  narrationTimers = [];
}

function goToSlide(idx, autoPlay = true) {
  currentSlide = Math.max(0, Math.min(idx, slides.length - 1));
  elapsedBeforePause = 0;
  clearNarrationTimers();
  if (playTimer) { clearTimeout(playTimer); playTimer = null; }
  clearSubtitle();
  renderSlide(currentSlide);
  updateProgress();
  if (autoPlay && isPlaying) {
    startSlideTimer();
  }
}

function startSlideTimer() {
  slideStartTime = Date.now() - elapsedBeforePause;
  scheduleNarrations(slides[currentSlide], elapsedBeforePause);
  const remaining = slides[currentSlide].duration - elapsedBeforePause;
  playTimer = setTimeout(() => {
    if (currentSlide < slides.length - 1) {
      elapsedBeforePause = 0;
      currentSlide++;
      renderSlide(currentSlide);
      startSlideTimer();
    } else {
      isPlaying = false;
      btnPlay.innerHTML = '&#9654;';
      clearSubtitle();
    }
  }, remaining);
}

function togglePlay() {
  if (isPlaying) {
    // Pause
    isPlaying = false;
    btnPlay.innerHTML = '&#9654;';
    if (playTimer) { clearTimeout(playTimer); playTimer = null; }
    clearNarrationTimers();
    elapsedBeforePause = Date.now() - slideStartTime;
  } else {
    // Play
    isPlaying = true;
    btnPlay.innerHTML = '&#9646;&#9646;';
    if (currentSlide >= slides.length - 1 && elapsedBeforePause >= slides[currentSlide].duration) {
      goToSlide(0, false);
    }
    startSlideTimer();
  }
}

function updateProgress() {
  // Calculate total elapsed
  let totalElapsed = 0;
  for (let i = 0; i < currentSlide; i++) totalElapsed += slides[i].duration;
  totalElapsed += elapsedBeforePause;
  const pct = (totalElapsed / totalDuration) * 100;
  progressFill.style.width = pct + '%';
  timeDisplay.textContent = `${formatTime(totalElapsed)} / ${formatTime(totalDuration)}`;
}

// Progress tick
setInterval(() => {
  if (isPlaying && playTimer) {
    const currentElapsed = Date.now() - slideStartTime;
    elapsedBeforePause = currentElapsed;
    updateProgress();
  }
}, 250);

// Build chapter pills and marks
const chapterList = document.getElementById('chapter-list');
const chapterMarks = document.getElementById('chapter-marks');
slides.forEach((slide, i) => {
  const pill = document.createElement('div');
  pill.className = 'chapter-pill';
  pill.textContent = slide.chapter;
  pill.dataset.index = i;
  pill.addEventListener('click', () => goToSlide(i));
  chapterList.appendChild(pill);

  let offset = 0;
  for (let j = 0; j < i; j++) offset += slides[j].duration;
  const pct = (offset / totalDuration) * 100;
  if (pct > 0 && pct < 100) {
    const mark = document.createElement('div');
    mark.className = 'chapter-mark';
    mark.style.left = pct + '%';
    chapterMarks.appendChild(mark);
  }
});

function updateChapterPills(idx) {
  document.querySelectorAll('.chapter-pill').forEach((p, i) => {
    p.classList.toggle('active', i === idx);
  });
}

// Progress bar click
document.getElementById('progress-wrap').addEventListener('click', (e) => {
  const rect = e.currentTarget.getBoundingClientRect();
  const pct = (e.clientX - rect.left) / rect.width;
  const targetTime = pct * totalDuration;
  let acc = 0;
  for (let i = 0; i < slides.length; i++) {
    if (acc + slides[i].duration > targetTime) {
      currentSlide = i;
      elapsedBeforePause = targetTime - acc;
      renderSlide(currentSlide);
      updateProgress();
      if (isPlaying) startSlideTimer();
      break;
    }
    acc += slides[i].duration;
  }
});

btnPlay.addEventListener('click', togglePlay);
btnPrev.addEventListener('click', () => {
  if (currentSlide > 0) goToSlide(currentSlide - 1);
});
btnNext.addEventListener('click', () => {
  if (currentSlide < slides.length - 1) goToSlide(currentSlide + 1);
});

// Keyboard controls
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
    if (currentSlide < slides.length - 1) goToSlide(currentSlide + 1);
  } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
    if (currentSlide > 0) goToSlide(currentSlide - 1);
  } else if (e.key === ' ') {
    e.preventDefault();
    togglePlay();
  }
});

// Init
renderSlide(0);
updateProgress();
updateChapterPills(0);
</script>
</body>
</html>

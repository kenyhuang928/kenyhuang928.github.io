<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>扫码下单操作手册 — 产品演示视频</title>
<style>
/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --primary: #0052CC;
  --primary-light: #0066FF;
  --accent: #FF5630;
  --success: #00875A;
  --warn: #FF8B00;
  --bg-dark: #0A0E1A;
  --bg-panel: #121828;
  --bg-card: #1A2235;
  --text-main: #E8EBF2;
  --text-sub: #8B96A8;
  --border: rgba(255,255,255,0.08);
  --slide-w: 1280px;
  --slide-h: 720px;
}
html, body {
  width: 100%; height: 100%;
  background: var(--bg-dark);
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
  color: var(--text-main);
  overflow: hidden;
}

/* ===== OUTER SHELL ===== */
#app {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100vw;
  height: 100vh;
  position: relative;
}

/* ===== STAGE ===== */
#stage-wrap {
  position: relative;
  width: 100%;
  max-width: var(--slide-w);
  aspect-ratio: 16/9;
  background: #000;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 24px 80px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06);
}
#stage {
  position: absolute;
  inset: 0;
}

/* ===== SLIDES ===== */
.slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.7s ease;
}
.slide.active {
  opacity: 1;
  pointer-events: all;
}
.slide.exit {
  opacity: 0;
}

/* ===== SLIDE BG TYPES ===== */
.slide-dark { background: var(--bg-dark); }
.slide-light { background: #F4F6FA; color: #1A2235; }
.slide-cover {
  background: linear-gradient(135deg, #0A0E1A 0%, #0D1B3E 50%, #051025 100%);
}

/* ===== COVER SLIDE ===== */
.cover-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}
.cover-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,82,204,0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,82,204,0.08) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: gridDrift 20s linear infinite;
}
@keyframes gridDrift {
  0% { transform: translate(0,0); }
  100% { transform: translate(60px, 60px); }
}
.cover-glow {
  position: absolute;
  width: 600px; height: 600px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(0,82,204,0.25) 0%, transparent 70%);
  top: 50%; left: 30%;
  transform: translate(-50%, -50%);
  animation: glowPulse 4s ease-in-out infinite;
}
@keyframes glowPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.8; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
}
.cover-content {
  position: relative;
  z-index: 2;
  display: flex;
  height: 100%;
  align-items: center;
  padding: 0 80px;
}
.cover-left { flex: 1; }
.cover-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(0,82,204,0.2);
  border: 1px solid rgba(0,82,204,0.4);
  border-radius: 20px;
  padding: 6px 16px;
  font-size: 13px;
  color: #7BA3FF;
  margin-bottom: 28px;
  letter-spacing: 0.5px;
  opacity: 0;
  animation: fadeUp 0.8s 0.3s forwards;
}
.cover-badge::before {
  content: '';
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #7BA3FF;
  animation: blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.cover-title {
  font-size: 64px;
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -1px;
  opacity: 0;
  animation: fadeUp 0.8s 0.5s forwards;
}
.cover-title em {
  font-style: normal;
  color: #4A90FF;
  position: relative;
}
.cover-title em::after {
  content: '';
  position: absolute;
  bottom: 4px; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, #0052CC, #4A90FF);
  border-radius: 2px;
}
.cover-subtitle {
  font-size: 18px;
  color: var(--text-sub);
  margin-top: 20px;
  letter-spacing: 0.3px;
  opacity: 0;
  animation: fadeUp 0.8s 0.7s forwards;
}
.cover-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 36px;
  opacity: 0;
  animation: fadeUp 0.8s 0.9s forwards;
}
.cover-tag {
  padding: 8px 20px;
  border-radius: 6px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  font-size: 14px;
  color: #C8D0E0;
}
.cover-right {
  width: 380px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  opacity: 0;
  animation: fadeLeft 0.8s 1.1s forwards;
}
.cover-menu-item {
  display: flex;
  align-items: center;
  gap: 16px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  padding: 14px 20px;
  transition: all 0.3s;
}
.cover-menu-item:hover {
  background: rgba(0,82,204,0.15);
  border-color: rgba(0,82,204,0.3);
  transform: translateX(4px);
}
.cover-menu-num {
  width: 28px; height: 28px;
  border-radius: 50%;
  background: rgba(0,82,204,0.3);
  border: 1px solid rgba(0,82,204,0.5);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700; color: #7BA3FF;
  flex-shrink: 0;
}
.cover-menu-text { font-size: 14px; color: var(--text-main); }
.cover-menu-desc { font-size: 11px; color: var(--text-sub); margin-top: 2px; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeLeft {
  from { opacity: 0; transform: translateX(20px); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ===== CONTENT SLIDE LAYOUT ===== */
.cs-layout {
  display: flex;
  flex-direction: column;
  height: 100%;
}
.cs-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px 48px 0;
  flex-shrink: 0;
}
.cs-part-badge {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--primary-light);
  background: rgba(0,82,204,0.15);
  border: 1px solid rgba(0,82,204,0.3);
  border-radius: 4px;
  padding: 3px 10px;
  white-space: nowrap;
}
.cs-title {
  font-size: 26px;
  font-weight: 700;
  color: var(--text-main);
  flex: 1;
}
.slide-light .cs-title { color: #0A1628; }
.cs-divider {
  height: 1px;
  background: linear-gradient(90deg, rgba(0,82,204,0.6) 0%, rgba(0,82,204,0.1) 60%, transparent 100%);
  margin: 14px 48px 0;
}
.cs-body {
  flex: 1;
  padding: 20px 48px 20px;
  overflow: hidden;
  display: flex;
  gap: 28px;
}

/* ===== STEP CARDS ===== */
.steps-col {
  display: flex;
  flex-direction: column;
  gap: 14px;
  flex: 1;
}
.step-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px 18px;
  opacity: 0;
  transform: translateX(-20px);
  transition: all 0.5s;
}
.slide-light .step-card {
  background: #fff;
  border-color: #E2E8F0;
}
.step-card.visible {
  opacity: 1;
  transform: translateX(0);
}
.step-num {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: #fff;
  flex-shrink: 0;
}
.step-content { flex: 1; min-width: 0; }
.step-title {
  font-size: 14px; font-weight: 600;
  color: var(--text-main);
  margin-bottom: 4px;
}
.slide-light .step-title { color: #0A1628; }
.step-desc {
  font-size: 12px;
  color: var(--text-sub);
  line-height: 1.6;
  white-space: pre-line;
}

/* ===== SCREENSHOT PANEL ===== */
.screenshot-panel {
  width: 380px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
  opacity: 0;
  transform: translateX(20px);
  transition: all 0.6s 0.3s;
}
.screenshot-panel.visible {
  opacity: 1;
  transform: translateX(0);
}
.screenshot-frame {
  flex: 1;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: #000;
  position: relative;
}
.screenshot-frame img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}
.screenshot-label {
  font-size: 11px;
  color: var(--text-sub);
  text-align: center;
  padding: 4px;
}

/* ===== INFO BLOCKS ===== */
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px 16px;
  background: var(--bg-card);
  border-radius: 8px;
  border: 1px solid var(--border);
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.4s;
}
.slide-light .info-row {
  background: #fff;
  border-color: #E2E8F0;
}
.info-row.visible { opacity: 1; transform: translateY(0); }
.info-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--primary-light);
  margin-top: 5px;
  flex-shrink: 0;
}
.info-text { font-size: 13px; line-height: 1.6; color: var(--text-main); }
.slide-light .info-text { color: #2D3748; }
.info-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--primary-light);
  display: block;
  margin-bottom: 3px;
}

/* ===== NOTICE BOX ===== */
.notice-box {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: rgba(0,82,204,0.1);
  border: 1px solid rgba(0,82,204,0.25);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 12px;
  color: #7BA3FF;
  line-height: 1.6;
  flex-shrink: 0;
  opacity: 0;
  transition: opacity 0.5s 1.2s;
}
.notice-box.visible { opacity: 1; }
.notice-box.warn {
  background: rgba(255,139,0,0.1);
  border-color: rgba(255,139,0,0.3);
  color: #FFAB40;
}
.notice-icon { font-size: 16px; flex-shrink: 0; }

/* ===== COLUMNS LAYOUT ===== */
.cols-3 {
  display: flex;
  gap: 20px;
  flex: 1;
}
.col-block {
  flex: 1;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 18px 16px;
  opacity: 0;
  transform: translateY(15px);
  transition: all 0.5s;
}
.slide-light .col-block { background: #fff; border-color: #E2E8F0; }
.col-block.visible { opacity: 1; transform: translateY(0); }
.col-icon {
  font-size: 24px;
  margin-bottom: 10px;
  display: block;
}
.col-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 2px solid rgba(0,82,204,0.3);
}
.slide-light .col-title { color: #0A1628; }
.col-item {
  display: flex;
  gap: 8px;
  align-items: flex-start;
  margin-bottom: 8px;
  font-size: 12px;
  color: var(--text-sub);
  line-height: 1.55;
}
.slide-light .col-item { color: #4A5568; }
.col-item::before {
  content: '•';
  color: var(--primary-light);
  flex-shrink: 0;
  margin-top: 1px;
}

/* ===== STEP FLOW (STEP 2 col) ===== */
.flow-steps {
  display: flex;
  gap: 0;
  align-items: stretch;
  flex: 1;
}
.flow-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  opacity: 0;
  transform: translateY(15px);
  transition: all 0.5s;
}
.flow-step.visible { opacity: 1; transform: translateY(0); }
.flow-step-icon {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0,82,204,0.3), rgba(0,102,255,0.15));
  border: 2px solid rgba(0,82,204,0.4);
  display: flex; align-items: center; justify-content: center;
  font-size: 24px;
  position: relative;
}
.flow-arrow {
  flex: 0 0 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 16px;
  color: var(--text-sub);
  font-size: 18px;
}
.flow-step-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-main);
  text-align: center;
}
.slide-light .flow-step-title { color: #0A1628; }
.flow-step-desc {
  font-size: 11px;
  color: var(--text-sub);
  text-align: center;
  line-height: 1.5;
}

/* ===== STEP BRANCHES ===== */
.branches-layout {
  display: flex;
  gap: 24px;
  flex: 1;
}
.branch-col { flex: 1; display: flex; flex-direction: column; gap: 12px; }
.branch-title {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: var(--primary-light);
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(0,82,204,0.2);
  margin-bottom: 4px;
}
.branch-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 16px;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.4s;
}
.slide-light .branch-card { background: #fff; border-color: #E2E8F0; }
.branch-card.visible { opacity: 1; transform: translateY(0); }
.branch-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-sub);
  margin-bottom: 6px;
}
.branch-result {
  font-size: 12.5px;
  color: var(--text-main);
  line-height: 1.65;
}
.slide-light .branch-result { color: #2D3748; }
.branch-result .opt {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: rgba(0,82,204,0.1);
  border-radius: 4px;
  padding: 1px 7px;
  color: var(--primary-light);
  font-size: 12px;
  margin: 2px 0;
}
.branch-result .opt-warn {
  background: rgba(255,139,0,0.1);
  color: #FFAB40;
}

/* ===== TABLE-LIKE ROWS ===== */
.field-table {
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.field-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  opacity: 0;
  transform: translateX(-15px);
  transition: all 0.4s;
}
.slide-light .field-row { background: #fff; border-color: #E2E8F0; }
.field-row.visible { opacity: 1; transform: translateX(0); }
.field-name {
  width: 110px;
  flex-shrink: 0;
  background: rgba(0,82,204,0.12);
  padding: 10px 12px;
  font-size: 12.5px;
  font-weight: 600;
  color: var(--primary-light);
  display: flex;
  align-items: center;
  line-height: 1.4;
}
.slide-light .field-name { background: rgba(0,82,204,0.06); color: var(--primary); }
.field-required {
  font-size: 10px;
  color: #FF5630;
  display: block;
  margin-top: 2px;
}
.field-desc {
  flex: 1;
  padding: 10px 14px;
  font-size: 12px;
  color: var(--text-sub);
  line-height: 1.6;
}
.slide-light .field-desc { color: #4A5568; }

/* ===== ORDER CONFIRM TABLE ===== */
.order-table {
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}
.order-row {
  display: flex;
  align-items: flex-start;
  gap: 0;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--border);
  opacity: 0;
  transition: all 0.35s;
  transform: translateY(8px);
}
.slide-light .order-row { border-color: #E2E8F0; }
.order-row.visible { opacity: 1; transform: translateY(0); }
.order-key {
  width: 130px;
  flex-shrink: 0;
  background: rgba(0,82,204,0.1);
  padding: 8px 12px;
  font-size: 12px;
  font-weight: 600;
  color: var(--primary-light);
  display: flex;
  align-items: center;
}
.slide-light .order-key { background: #EEF2FF; color: var(--primary); }
.order-val {
  flex: 1;
  padding: 8px 12px;
  font-size: 12px;
  color: var(--text-sub);
  line-height: 1.55;
  background: var(--bg-card);
}
.slide-light .order-val { background: #fff; color: #4A5568; }

/* ===== SUMMARY SLIDE ===== */
.summary-slide {
  background: linear-gradient(160deg, #0A0E1A 0%, #0D1B3E 100%);
}
.summary-flow {
  display: flex;
  gap: 0;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 0 48px;
}
.summary-item {
  flex: 1;
  text-align: center;
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.5s;
  padding: 0 8px;
}
.summary-item.visible { opacity: 1; transform: translateY(0); }
.summary-circle {
  width: 70px; height: 70px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0,82,204,0.4), rgba(0,102,255,0.2));
  border: 2px solid rgba(0,82,204,0.5);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  margin: 0 auto 12px;
  position: relative;
}
.summary-circle-num {
  position: absolute;
  top: -4px; right: -4px;
  width: 20px; height: 20px;
  border-radius: 50%;
  background: var(--primary);
  font-size: 11px;
  font-weight: 700;
  color: #fff;
  display: flex; align-items: center; justify-content: center;
}
.summary-arrow {
  flex: 0 0 28px;
  text-align: center;
  color: rgba(0,82,204,0.6);
  font-size: 20px;
  padding-bottom: 20px;
}
.summary-label {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 6px;
}
.summary-desc {
  font-size: 11px;
  color: var(--text-sub);
  line-height: 1.5;
}
.summary-footer {
  text-align: center;
  padding: 16px 48px 20px;
  font-size: 13px;
  color: var(--text-sub);
  opacity: 0;
  transition: opacity 0.5s 2s;
}
.summary-footer.visible { opacity: 1; }

/* ===== QR SECTION (Slide 11) ===== */
.qr-slide-body {
  flex: 1;
  display: flex;
  gap: 28px;
  padding: 16px 48px 20px;
  overflow: hidden;
}
.qr-steps { flex: 1; display: flex; flex-direction: column; gap: 12px; }
.qr-path-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(0,82,204,0.1);
  border: 1px solid rgba(0,82,204,0.25);
  border-radius: 6px;
  padding: 8px 14px;
  font-size: 12px;
  color: #7BA3FF;
  flex-shrink: 0;
}
.qr-path-sep { color: rgba(0,82,204,0.4); }

/* ===== SUBTITLE / NARRATION BAR ===== */
#subtitle-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 70%, transparent 100%);
  padding: 24px 48px 16px;
  pointer-events: none;
  z-index: 100;
  transition: opacity 0.4s;
}
.subtitle-text {
  font-size: 18px;
  font-weight: 400;
  color: #fff;
  text-shadow: 0 1px 4px rgba(0,0,0,0.8);
  line-height: 1.6;
  letter-spacing: 0.3px;
  text-align: center;
  min-height: 28px;
  opacity: 0;
  transition: opacity 0.4s;
}
.subtitle-text.visible { opacity: 1; }

/* ===== CONTROLS ===== */
#controls {
  width: 100%;
  max-width: var(--slide-w);
  padding: 12px 0 0;
}
.progress-wrap {
  width: 100%;
  height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 2px;
  cursor: pointer;
  position: relative;
  margin-bottom: 10px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 2px;
  width: 0%;
